# ─── Lab Interpreter — Variáveis de Ambiente para Produção ───────────────────
# Copie este arquivo para .env e preencha os valores:
#   cp env.template .env && nano .env
#
# NUNCA commite o arquivo .env no Git (já está no .gitignore)

# ─── Aplicação ────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# Domínio de produção (usado nas labels do Traefik)
DOMAIN=labinterpreter.drzacher.com

# Para testes locais sem Traefik (docker-compose.local.yml):
# LOCAL_PORT=3001

# ─── Banco de Dados MySQL ─────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=ALTERE_SENHA_ROOT_FORTE
MYSQL_DATABASE=lab_interpreter
MYSQL_USER=labuser
MYSQL_PASSWORD=ALTERE_SENHA_LABUSER_FORTE

# ─── Segurança JWT ────────────────────────────────────────────────────────────
# Gere com: openssl rand -hex 32
JWT_SECRET=GERE_UMA_STRING_ALEATORIA_DE_64_CHARS

# ─── Storage MinIO (dedicado ao lab-interpreter) ──────────────────────────────
MINIO_ROOT_USER=labadmin
MINIO_ROOT_PASSWORD=ALTERE_SENHA_MINIO_FORTE
MINIO_BUCKET=lab-interpreter-files

# ─── Ollama (IA Local) ────────────────────────────────────────────────────────
# URL interna após: docker network connect ollama-hd0v_default lab-interpreter-app
OLLAMA_BASE_URL=http://ollama-hd0v-ollama-1:11434
# Modelo a usar (verifique os disponíveis: docker exec ollama-hd0v-ollama-1 ollama list)
OLLAMA_MODEL=llama3.2

# ─── Traefik / Let's Encrypt ──────────────────────────────────────────────────
# Email para notificações de certificado SSL
ACME_EMAIL=seu@email.com
