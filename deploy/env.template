# ─── Lab Interpreter — Variáveis de Ambiente de Produção ─────────────────────
# Copie este arquivo para .env e preencha os valores antes de fazer o deploy.
# NUNCA commite o arquivo .env no repositório.

# ─── Banco de Dados MySQL ──────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=SenhaRootForteAqui123!
MYSQL_DATABASE=lab_interpreter
MYSQL_USER=labuser
MYSQL_PASSWORD=SenhaLabUserForteAqui456!

# ─── Segurança ────────────────────────────────────────────────────────────────
# Gere com: openssl rand -base64 64
JWT_SECRET=gere_uma_chave_secreta_forte_aqui_com_openssl_rand_base64_64

# ─── Autenticação ─────────────────────────────────────────────────────────────
# Modo de autenticação: "local" (usuário/senha) ou "google" (OAuth Google)
AUTH_MODE=local

# ─── Storage ──────────────────────────────────────────────────────────────────
# Modo de armazenamento: "local" (pasta na VPS)
STORAGE_MODE=local
STORAGE_LOCAL_PATH=/app/uploads

# ─── IA Local (Ollama) ────────────────────────────────────────────────────────
# URL do Ollama já rodando na VPS (para integração futura)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2
